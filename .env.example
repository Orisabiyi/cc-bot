# ═══════════════════════════════════════════════════
# Common Chronicles Content Bot — Environment Config
# ═══════════════════════════════════════════════════

# ─── Notion ───
# 1. Create an integration at https://www.notion.so/my-integrations
# 2. Share your Content Pipeline database with the integration
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_CONTENT_DB_ID=1b6b3a4b79674695861f0e4d1b9f934e

# ─── Discord ───
# Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_server_id_here

# ─── Channel IDs ───
# Enable Developer Mode: Discord Settings → Advanced → Developer Mode
# Then right-click each channel → Copy Channel ID
#
# ── info ──
DISCORD_CHANNEL_RULES=channel_id_here
DISCORD_CHANNEL_MODERATOR_ONLY=channel_id_here
#
# ── Start Here ──
DISCORD_CHANNEL_WELCOME=channel_id_here
DISCORD_CHANNEL_INTRODUCTIONS=channel_id_here
DISCORD_CHANNEL_PICK_YOUR_ROLE=channel_id_here
#
# ── community ──
DISCORD_CHANNEL_GENERAL=channel_id_here
DISCORD_CHANNEL_SHOWCASE=channel_id_here
DISCORD_CHANNEL_OFF_TOPIC=channel_id_here
#
# ── updates ──
DISCORD_CHANNEL_ANNOUNCEMENTS=channel_id_here
DISCORD_CHANNEL_PODCAST_BLOG=channel_id_here
#
# ── programs ──
DISCORD_CHANNEL_STORY_CIRCLES=channel_id_here
DISCORD_CHANNEL_GLOBAL_SPOTLIGHTS=channel_id_here
DISCORD_CHANNEL_FAILURE_FRIDAYS=channel_id_here
DISCORD_CHANNEL_COMMONS_PROJECTS=channel_id_here
#
# ── resources ──
DISCORD_CHANNEL_MATERIALS=channel_id_here
DISCORD_CHANNEL_JOB_BOARD=channel_id_here
DISCORD_CHANNEL_TECH_EVENTS=channel_id_here
DISCORD_CHANNEL_HANGOUTS=channel_id_here

# Your personal Discord user ID (for DM reminders)
# Right-click your username → Copy User ID
DISCORD_OWNER_ID=your_discord_user_id_here

# ─── Timezone ───
TIMEZONE=Africa/Lagos

# ─── Logging ───
LOG_LEVEL=info
